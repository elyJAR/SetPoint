rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow anyone to read user schedules (for sharing)
    // Only the owner can write/update their own schedule
    match /user_schedules/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
